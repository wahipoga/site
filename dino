<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Dino Game - Pixel Art Edition</title>
    <style>
        * {
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }
        
        body {
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #1a472a 0%, #2d5a3b 100%);
            font-family: 'Courier New', 'VT323', monospace;
            touch-action: manipulation;
        }
        
        .game-container {
            background: #2c2c2c;
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.1);
            border: 2px solid #5a5a5a;
        }
        
        canvas {
            border: 4px solid #1a1a1a;
            display: block;
            margin: 0 auto;
            background: #87CEEB;
            cursor: pointer;
            touch-action: none;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
            image-rendering: crisp-edges;
            image-rendering: pixelated;
        }
        
        .info {
            text-align: center;
            margin-top: 20px;
        }
        
        .score-panel {
            background: #1a1a1a;
            display: inline-block;
            padding: 10px 30px;
            border-radius: 10px;
            margin-bottom: 15px;
            box-shadow: inset 0 2px 5px rgba(0,0,0,0.5), 0 2px 0 #4a4a4a;
        }
        
        .score-label {
            color: #ffd700;
            font-size: 18px;
            letter-spacing: 2px;
            text-shadow: 0 0 5px rgba(255,215,0,0.5);
        }
        
        .score-value {
            color: #ffd700;
            font-size: 32px;
            font-weight: bold;
            margin-left: 15px;
            text-shadow: 0 0 5px rgba(255,215,0,0.5);
        }
        
        .controls {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 15px;
            flex-wrap: wrap;
        }
        
        button {
            background: linear-gradient(180deg, #4a4a4a 0%, #2a2a2a 100%);
            color: #ffd700;
            border: none;
            padding: 12px 28px;
            font-size: 18px;
            font-weight: bold;
            border-radius: 8px;
            cursor: pointer;
            font-family: 'Courier New', monospace;
            transition: all 0.1s ease;
            box-shadow: 0 4px 0 #1a1a1a;
            text-shadow: 0 1px 0 #1a1a1a;
            touch-action: manipulation;
        }
        
        button:active {
            transform: translateY(2px);
            box-shadow: 0 2px 0 #1a1a1a;
        }
        
        .message {
            color: #aaa;
            font-size: 12px;
            margin-top: 12px;
            letter-spacing: 1px;
        }
        
        .blink-o {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 120px;
            font-weight: bold;
            font-family: monospace;
            color: #ff0000;
            text-shadow: 0 0 20px rgba(255,0,0,0.8), 0 0 40px rgba(255,0,0,0.5);
            z-index: 1000;
            pointer-events: none;
            animation: blinkLetter 0.15s infinite;
        }
        
        @keyframes blinkLetter {
            0%, 100% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
            50% { opacity: 0; transform: translate(-50%, -50%) scale(1.2); }
        }
        
        @media (max-width: 768px) {
            .score-value { font-size: 24px; }
            button { padding: 10px 20px; font-size: 14px; }
            .blink-o { font-size: 80px; }
        }
    </style>
</head>
<body>
    <div class="game-container">
        <canvas id="gameCanvas" width="800" height="400"></canvas>
        <div class="info">
            <div class="score-panel">
                <span class="score-label">🏆 PONTUAÇÃO 🏆</span>
                <span class="score-value" id="score">0</span>
            </div>
            <div class="controls">
                <button id="jumpBtn">🦖 PULAR ⬆️</button>
                <button id="restartBtn">🔄 REINICIAR</button>
            </div>
            <div class="message">
                💡 CLIQUE / TOQUE / ESPAÇO para pular | CUIDADO COM O QUE VEM POR AÍ...
            </div>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        
        // Pixel art - ativar renderização pixelada
        ctx.imageSmoothingEnabled = false;
        
        // Configurações
        const GRAVIDADE = 0.6;
        const FORCA_PULO = -9.5;
        const VELOCIDADE_INICIAL = 4;
        const DISTANCIA_MINIMA_OBSTACULOS = 350;
        const PONTOS_PARA_GLITCH = 50; // Segredo! O jogador não sabe disso
        
        // Objeto do jogador (pixel art)
        const jogador = {
            x: 80,
            y: 0,
            altura: 35,
            largura: 28,
            velocidadeY: 0,
            noChao: true,
            framePerna: 0,
            
            pular() {
                if (this.noChao) {
                    this.velocidadeY = FORCA_PULO;
                    this.noChao = false;
                }
            },
            
            atualizar() {
                this.y += this.velocidadeY;
                this.velocidadeY += GRAVIDADE;
                
                if (this.y >= canvas.height - this.altura - 50) {
                    this.y = canvas.height - this.altura - 50;
                    this.noChao = true;
                    this.velocidadeY = 0;
                    this.framePerna = (this.framePerna + 0.2) % 2;
                }
                
                if (this.y < 0) {
                    this.y = 0;
                    this.velocidadeY = 0;
                }
            },
            
            desenhar() {
                // Corpo do dinossauro (pixel art)
                ctx.fillStyle = '#2d5a1e';
                ctx.fillRect(this.x, this.y, this.largura, this.altura);
                
                // Barriga
                ctx.fillStyle = '#4a8c2a';
                ctx.fillRect(this.x + 5, this.y + 10, this.largura - 10, 20);
                
                // Olho
                ctx.fillStyle = '#ffffff';
                ctx.fillRect(this.x + this.largura - 10, this.y + 8, 6, 6);
                ctx.fillStyle = '#000000';
                ctx.fillRect(this.x + this.largura - 9, this.y + 9, 4, 4);
                ctx.fillStyle = '#ffffff';
                ctx.fillRect(this.x + this.largura - 8, this.y + 10, 2, 2);
                
                // Crista nas costas
                ctx.fillStyle = '#1a3a0a';
                for(let i = 0; i < 3; i++) {
                    ctx.fillRect(this.x - 5 + i*8, this.y + 5 + i*8, 5, 8);
                }
                
                // Pernas (animação)
                if (this.noChao) {
                    const offset = Math.sin(this.framePerna * Math.PI) * 3;
                    ctx.fillStyle = '#2d5a1e';
                    ctx.fillRect(this.x + 5, this.y + this.altura - 2, 7, 12);
                    ctx.fillRect(this.x + 16, this.y + this.altura - 2, 7, 12);
                    ctx.fillStyle = '#1a3a0a';
                    ctx.fillRect(this.x + 5, this.y + this.altura + 8, 7, 4);
                    ctx.fillRect(this.x + 16, this.y + this.altura + 8, 7, 4);
                } else {
                    ctx.fillStyle = '#2d5a1e';
                    ctx.fillRect(this.x + 5, this.y + this.altura - 5, 7, 15);
                    ctx.fillRect(this.x + 16, this.y + this.altura - 5, 7, 15);
                }
                
                // Cauda
                ctx.fillStyle = '#2d5a1e';
                ctx.fillRect(this.x - 8, this.y + this.altura - 10, 8, 6);
            }
        };
        
        // Classe do obstáculo (cacto pixelado)
        class Obstaculo {
            constructor(tipo = 'normal') {
                this.x = canvas.width;
                this.largura = 22;
                this.altura = 32;
                this.y = canvas.height - this.altura - 50;
                this.tipo = tipo;
                this.ativo = true;
            }
            
            atualizar() {
                this.x -= velocidade;
            }
            
            desenhar() {
                if (this.tipo === 'glitch') {
                    // Obstáculo glitch com efeito pixelado - SURPRESA!
                    ctx.save();
                    
                    // Efeito de corrupção visual
                    for(let i = 0; i < 5; i++) {
                        if(Math.random() > 0.7) {
                            ctx.fillStyle = `rgba(255, ${Math.random() * 255}, 255, 0.8)`;
                            ctx.fillRect(this.x + (Math.random() - 0.5) * 8, 
                                       this.y + (Math.random() - 0.5) * 8, 
                                       this.largura, this.altura);
                        }
                    }
                    
                    // Corpo principal do glitch
                    ctx.fillStyle = '#ff00ff';
                    ctx.fillRect(this.x, this.y, this.largura, this.altura);
                    
                    // Padrão de glitch
                    ctx.fillStyle = '#ff0000';
                    for(let i = 0; i < 4; i++) {
                        ctx.fillRect(this.x + 3 + i*4, this.y + 5, 2, 8);
                        ctx.fillRect(this.x + 3 + i*4, this.y + 20, 2, 8);
                    }
                    
                    ctx.fillStyle = '#00ff00';
                    ctx.fillRect(this.x + 8, this.y + 12, 6, 8);
                    
                    ctx.restore();
                } else {
                    // Cacto normal (pixel art)
                    ctx.fillStyle = '#2d6b1e';
                    ctx.fillRect(this.x + 8, this.y - 15, 6, 20);
                    ctx.fillRect(this.x + 8, this.y - 15, 6, 20);
                    
                    // Corpo principal
                    ctx.fillStyle = '#3a8a2a';
                    ctx.fillRect(this.x, this.y, this.largura, this.altura);
                    
                    // Detalhes do cacto
                    ctx.fillStyle = '#2a6a1a';
                    ctx.fillRect(this.x + 4, this.y - 12, 5, 15);
                    ctx.fillRect(this.x + 13, this.y - 8, 5, 12);
                    
                    // Espinhos
                    ctx.fillStyle = '#ffff00';
                    for(let i = 0; i < 3; i++) {
                        ctx.fillRect(this.x + 2, this.y + 5 + i*10, 2, 2);
                        ctx.fillRect(this.x + 18, this.y + 5 + i*10, 2, 2);
                    }
                    
                    // Sombras
                    ctx.fillStyle = '#1a4a0a';
                    ctx.fillRect(this.x + 2, this.y + 5, 3, 22);
                }
            }
            
            colidiu(jogador) {
                return (jogador.x < this.x + this.largura &&
                       jogador.x + jogador.largura > this.x &&
                       jogador.y < this.y + this.altura &&
                       jogador.y + jogador.altura > this.y);
            }
        }
        
        // Variáveis globais
        let obstaculos = [];
        let pontuacao = 0;
        let velocidade = VELOCIDADE_INICIAL;
        let jogoAtivo = true;
        let frameCount = 0;
        let glitchAtivo = false;
        let glitchObstaculoGerado = false;
        let animacaoId = null;
        let ultimoObstaculoX = canvas.width;
        
        // Função para piscar a letra O (SURPRESA FINAL)
        function piscarLetraO() {
            return new Promise((resolve) => {
                let contador = 0;
                const blinkElement = document.createElement('div');
                blinkElement.className = 'blink-o';
                blinkElement.textContent = 'O';
                document.body.appendChild(blinkElement);
                
                // Efeito de vibração na tela
                canvas.style.animation = 'screenGlitch 0.05s infinite';
                
                const interval = setInterval(() => {
                    contador++;
                    if (contador >= 10) {
                        clearInterval(interval);
                        blinkElement.remove();
                        canvas.style.animation = '';
                        resolve();
                    }
                }, 150);
            });
        }
        
        // Adicionar efeito de screenGlitch se não existir
        const style = document.createElement('style');
        style.textContent = `
            @keyframes screenGlitch {
                0% { transform: translate(0); }
                20% { transform: translate(-2px, 1px); }
                40% { transform: translate(2px, -1px); }
                60% { transform: translate(-1px, 2px); }
                80% { transform: translate(1px, -2px); }
                100% { transform: translate(0); }
            }
        `;
        document.head.appendChild(style);
        
        // Gerar obstáculos com distância mínima
        function gerarObstaculo() {
            // Verifica se o último obstáculo está longe o suficiente
            let podeGerar = true;
            if (obstaculos.length > 0) {
                const ultimoObstaculo = obstaculos[obstaculos.length - 1];
                if (ultimoObstaculo.x > canvas.width - DISTANCIA_MINIMA_OBSTACULOS) {
                    podeGerar = false;
                }
            }
            
            // Chance de gerar
            const chanceGerar = 0.015;
            
            if (podeGerar && Math.random() < chanceGerar && obstaculos.length < 2) {
                let tipo = 'normal';
                
                // Verificar se deve gerar obstáculo glitch - SEM AVISO!
                if (pontuacao >= PONTOS_PARA_GLITCH && !glitchObstaculoGerado && !glitchAtivo) {
                    tipo = 'glitch';
                    glitchObstaculoGerado = true;
                    glitchAtivo = true;
                    
                    // Efeito visual sútil de surpresa
                    canvas.style.animation = 'screenGlitch 0.2s';
                    setTimeout(() => {
                        canvas.style.animation = '';
                    }, 200);
                }
                
                obstaculos.push(new Obstaculo(tipo));
                ultimoObstaculoX = canvas.width;
            }
        }
        
        // Atualizar obstáculos
        function atualizarObstaculos() {
            for(let i = 0; i < obstaculos.length; i++) {
                obstaculos[i].atualizar();
                
                if(obstaculos[i].x + obstaculos[i].largura < 0) {
                    obstaculos.splice(i, 1);
                    i--;
                    
                    if(!jogoAtivo) continue;
                    
                    // Aumentar pontuação
                    pontuacao += 5;
                    document.getElementById('score').textContent = Math.floor(pontuacao);
                    
                    // Aumentar velocidade gradualmente
                    if(pontuacao % 50 === 0 && velocidade < 9) {
                        velocidade += 0.3;
                    }
                    
                    // Resetar flag do glitch
                    if(glitchAtivo && obstaculos.length === 0) {
                        glitchAtivo = false;
                        glitchObstaculoGerado = false;
                    }
                }
            }
            
            gerarObstaculo();
        }
        
        // Verificar colisões
        function verificarColisoes() {
            for(let i = 0; i < obstaculos.length; i++) {
                if(obstaculos[i].colidiu(jogador)) {
                    if(obstaculos[i].tipo === 'glitch') {
                        gameOver('glitch');
                    } else {
                        gameOver('normal');
                    }
                    return true;
                }
            }
            return false;
        }
        
        // Desenhar chão (pixel art)
        function desenharChao() {
            // Chão principal
            ctx.fillStyle = '#8B6946';
            ctx.fillRect(0, canvas.height - 50, canvas.width, 8);
            
            // Grama pixelada
            ctx.fillStyle = '#4a8c2a';
            for(let i = 0; i < canvas.width; i += 12) {
                ctx.fillRect(i, canvas.height - 55, 3, 8);
                ctx.fillRect(i + 4, canvas.height - 53, 2, 6);
            }
            
            // Detalhes do chão
            ctx.fillStyle = '#6a4a2a';
            for(let i = 0; i < canvas.width; i += 20) {
                ctx.fillRect(i, canvas.height - 48, 2, 3);
            }
        }
        
        // Desenhar nuvens pixeladas
        function desenharNuvens() {
            const tempo = (Date.now() / 100) % (canvas.width * 2);
            
            // Nuvem 1
            ctx.fillStyle = '#f0f0f0';
            ctx.fillRect((tempo * 0.3) % (canvas.width + 200) - 100, 60, 30, 20);
            ctx.fillRect((tempo * 0.3) % (canvas.width + 200) - 100 + 20, 50, 25, 25);
            ctx.fillRect((tempo * 0.3) % (canvas.width + 200) - 100 + 45, 55, 25, 20);
            
            // Nuvem 2
            ctx.fillStyle = '#e0e0e0';
            ctx.fillRect((tempo * 0.2 + 200) % (canvas.width + 300) - 150, 100, 35, 22);
            ctx.fillRect((tempo * 0.2 + 200) % (canvas.width + 300) - 150 + 25, 90, 28, 28);
            ctx.fillRect((tempo * 0.2 + 200) % (canvas.width + 300) - 150 + 55, 95, 30, 22);
        }
        
        // Desenhar sol pixelado
        function desenharSol() {
            ctx.fillStyle = '#ffdd00';
            ctx.fillRect(canvas.width - 70, 30, 30, 30);
            
            // Raios
            ctx.fillStyle = '#ffaa00';
            for(let i = 0; i < 8; i++) {
                const angle = (Date.now() / 500 + i) * Math.PI * 2 / 8;
                const x = canvas.width - 55 + Math.cos(angle) * 25;
                const y = 45 + Math.sin(angle) * 25;
                ctx.fillRect(x, y, 4, 4);
            }
        }
        
        // Aplicar efeito glitch na tela (sutil)
        function aplicarEfeitoGlitch() {
            if(glitchAtivo && jogoAtivo && Math.random() > 0.85) {
                const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                const data = imageData.data;
                
                for(let i = 0; i < data.length; i += 4) {
                    if(Math.random() > 0.98) {
                        data[i] = 255;     // R
                        data[i+1] = 0;     // G
                        data[i+2] = 255;   // B
                    }
                    if(Math.random() > 0.995) {
                        data[i] = Math.random() * 255;
                        data[i+1] = Math.random() * 255;
                        data[i+2] = Math.random() * 255;
                    }
                }
                
                ctx.putImageData(imageData, 0, 0);
            }
        }
        
        // Game over
        async function gameOver(tipo) {
            if(!jogoAtivo) return;
            
            jogoAtivo = false;
            
            if(tipo === 'glitch') {
                await piscarLetraO();
            }
            
            // Desenhar tela de game over (pixel art)
            ctx.fillStyle = 'rgba(0, 0, 0, 0.85)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            ctx.fillStyle = '#ff4444';
            ctx.font = 'bold 32px "Courier New", monospace';
            ctx.textAlign = 'center';
            ctx.fillText('GAME OVER', canvas.width/2, canvas.height/2 - 60);
            
            ctx.fillStyle = '#ffd700';
            ctx.font = '20px "Courier New", monospace';
            ctx.fillText(`PONTUAÇÃO: ${Math.floor(pontuacao)}`, canvas.width/2, canvas.height/2 - 10);
            
            if(tipo === 'glitch') {
                ctx.fillStyle = '#ff00ff';
                ctx.font = 'bold 16px "Courier New", monospace';
                ctx.fillText('⚠️ VOCÊ ENCONTROU O GLITCH... ⚠️', canvas.width/2, canvas.height/2 + 40);
                ctx.fillStyle = '#ff0000';
                ctx.font = '14px monospace';
                ctx.fillText('A LETRA "O" APARECEU...', canvas.width/2, canvas.height/2 + 80);
            } else {
                ctx.fillStyle = '#cccccc';
                ctx.font = '16px monospace';
                ctx.fillText('CLIQUE EM "REINICIAR" PARA JOGAR NOVAMENTE', canvas.width/2, canvas.height/2 + 50);
            }
            
            ctx.textAlign = 'left';
        }
        
        // Reiniciar jogo
        function reiniciar() {
            if(animacaoId) {
                cancelAnimationFrame(animacaoId);
            }
            
            obstaculos = [];
            pontuacao = 0;
            velocidade = VELOCIDADE_INICIAL;
            jogoAtivo = true;
            glitchAtivo = false;
            glitchObstaculoGerado = false;
            frameCount = 0;
            ultimoObstaculoX = canvas.width;
            
            jogador.y = canvas.height - jogador.altura - 50;
            jogador.velocidadeY = 0;
            jogador.noChao = true;
            
            document.getElementById('score').textContent = '0';
            canvas.style.animation = '';
            
            loop();
        }
        
        // Loop principal
        function loop() {
            if(!jogoAtivo) {
                animacaoId = requestAnimationFrame(loop);
                return;
            }
            
            // Limpar canvas
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Céu gradiente (pixel art)
            const gradiente = ctx.createLinearGradient(0, 0, 0, canvas.height);
            gradiente.addColorStop(0, '#87CEEB');
            gradiente.addColorStop(1, '#E0F0FF');
            ctx.fillStyle = gradiente;
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            // Desenhar elementos
            desenharSol();
            desenharNuvens();
            desenharChao();
            
            // Atualizar e desenhar jogador
            jogador.atualizar();
            jogador.desenhar();
            
            // Atualizar obstáculos
            atualizarObstaculos();
            
            // Desenhar obstáculos
            for(let obstaculo of obstaculos) {
                obstaculo.desenhar();
            }
            
            // Verificar colisão
            verificarColisoes();
            
            // Aplicar efeito glitch se necessário
            aplicarEfeitoGlitch();
            
            frameCount++;
            animacaoId = requestAnimationFrame(loop);
        }
        
        // Eventos de pulo
        function pular() {
            if(jogoAtivo && jogador.noChao) {
                jogador.pular();
                if('vibrate' in navigator) {
                    navigator.vibrate(30);
                }
            }
        }
        
        // Configurar eventos
        function setupEventos() {
            canvas.addEventListener('click', pular);
            canvas.addEventListener('touchstart', (e) => {
                e.preventDefault();
                pular();
            });
            
            document.getElementById('jumpBtn').addEventListener('click', pular);
            document.getElementById('jumpBtn').addEventListener('touchstart', (e) => {
                e.preventDefault();
                pular();
            });
            
            document.getElementById('restartBtn').addEventListener('click', () => {
                reiniciar();
            });
            document.getElementById('restartBtn').addEventListener('touchstart', (e) => {
                e.preventDefault();
                reiniciar();
            });
            
            document.addEventListener('keydown', (e) => {
                if(e.code === 'Space' || e.code === 'ArrowUp') {
                    e.preventDefault();
                    pular();
                }
                if(e.code === 'KeyR') {
                    e.preventDefault();
                    reiniciar();
                }
            });
        }
        
        // Inicializar
        function init() {
            jogador.y = canvas.height - jogador.altura - 50;
            setupEventos();
            loop();
        }
        
        init();
    </script>
</body>
</html>
